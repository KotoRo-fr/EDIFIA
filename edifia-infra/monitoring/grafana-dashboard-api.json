{
  "dashboard": {
    "id": null,
    "uid": "edifia-api-metrics",
    "title": "EDIFIA — API Metrics",
    "tags": ["edifia", "api", "sprint1"],
    "timezone": "Europe/Paris",
    "schemaVersion": 38,
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "interval",
          "type": "interval",
          "query": "1m,5m,10m,30m,1h",
          "current": {
            "text": "5m",
            "value": "5m"
          },
          "refresh": 2
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "min": 0,
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 20,
              "pointSize": 3
            }
          }
        },
        "targets": [
          {
            "expr": "rate(http_requests_total[$interval])",
            "legendFormat": "{{method}} {{handler}}",
            "refId": "A"
          }
        ],
        "datasource": "Prometheus"
      },
      {
        "id": 2,
        "title": "Latency p95",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "min": 0,
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10,
              "pointSize": 3
            }
          }
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[$interval]))",
            "legendFormat": "p95 {{handler}}",
            "refId": "A"
          }
        ],
        "datasource": "Prometheus"
      },
      {
        "id": 3,
        "title": "Error Rate (%)",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 20,
              "pointSize": 3
            },
            "thresholds": {
              "steps": [
                {
                  "value": 0,
                  "color": "green"
                },
                {
                  "value": 0.05,
                  "color": "yellow"
                },
                {
                  "value": 0.1,
                  "color": "red"
                }
              ]
            }
          }
        },
        "targets": [
          {
            "expr": "rate(http_requests_total{status=~\"5..\"}[$interval]) / rate(http_requests_total[$interval])",
            "legendFormat": "Error Rate",
            "refId": "A"
          }
        ],
        "datasource": "Prometheus"
      },
      {
        "id": 4,
        "title": "Status Codes",
        "type": "bargauge",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "displayMode": "gradient"
            }
          }
        },
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient",
          "showUnfilled": true
        },
        "targets": [
          {
            "expr": "count by (status) (http_requests_total)",
            "legendFormat": "{{status}}",
            "refId": "A",
            "instant": true,
            "format": "table"
          }
        ],
        "datasource": "Prometheus",
        "transformations": [
          {
            "id": "merge",
            "options": {}
          }
        ]
      }
    ]
  },
  "overwrite": true
}
